# joinheadstash.com environment variables.
# Copy this file to .env.local and fill in real values for local dev.
# Never commit .env.local: it is gitignored.

NEXT_PUBLIC_PLAUSIBLE_DOMAIN=joinheadstash.com
NEXT_PUBLIC_SITE_URL=https://joinheadstash.com

# Supabase: wired in step 3
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend: wired in step 3
RESEND_API_KEY=
RESEND_FROM_EMAIL=Headstash <onboarding@resend.dev>
NOTIFY_EMAIL=hello@getheadstash.com

# Twilio: wired later for SMS confirmation on waitlist signup
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
