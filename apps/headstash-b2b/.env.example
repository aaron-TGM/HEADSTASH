# getheadstash.com environment variables.
# Copy this file to .env.local and fill in real values for local dev.
# Never commit .env.local — it's gitignored.

# Plausible analytics domain (defaults to getheadstash.com in prod)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=getheadstash.com

# Canonical site URL used for metadata, sitemap, OG tags
NEXT_PUBLIC_SITE_URL=https://getheadstash.com

# Supabase — wired in step 3
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — wired in step 3
RESEND_API_KEY=
NOTIFY_EMAIL=hello@getheadstash.com
